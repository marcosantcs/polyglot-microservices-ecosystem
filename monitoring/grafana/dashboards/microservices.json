{
  "uid": "microservices-main",
  "title": "Polyglot Microservices Dashboard",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Total Orders",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "analytics_total_orders_total", "refId": "A"}]
    },
    {
      "id": 2,
      "title": "Total Revenue (R$)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "analytics_total_revenue_total", "refId": "A"}]
    },
    {
      "id": 3,
      "title": "Cancelled Orders",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "analytics_cancelled_orders_total", "refId": "A"}]
    },
    {
      "id": 4,
      "title": "Orders per Minute",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "rate(analytics_total_orders_total[1m])", "refId": "A", "legendFormat": "orders/min"}]
    },
    {
      "id": 5,
      "title": "RabbitMQ Queue Depth",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "rabbitmq_queue_messages{queue=~'orders.*'}", "refId": "A", "legendFormat": "{{queue}}"}]
    }
  ]
}
