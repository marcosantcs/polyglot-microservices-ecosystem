# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ordersdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# ─── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=orders.topic
RABBITMQ_QUEUE=analytics.queue
RABBITMQ_DLQ=orders.dlq

# ─── order-service (.NET 8) ────────────────────────────────
ASPNETCORE_URLS=http://+:8080
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=localhost;Database=ordersdb;Username=postgres;Password=your_password_here

# ─── analytics-service (Python) ────────────────────────────
ANALYTICS_PORT=8000
ANALYTICS_HOST=0.0.0.0

# ─── ai-service (Python + OpenAI) ──────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
AI_SERVICE_PORT=8001
AI_SERVICE_HOST=0.0.0.0
PDF_STORAGE_PATH=./uploads

# ─── Observability ─────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here

# ─── AWS (Terraform) ───────────────────────────────────────
AWS_REGION=us-east-1
TF_VAR_db_password=your_rds_password_here
TF_VAR_db_username=postgres
TF_VAR_db_name=ordersdb
